# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intelligence

# --- Auth (JWT) ---
JWT_SECRET=change-me-in-production-please
JWT_REFRESH_SECRET=change-me-too-in-production
AUTH_PROVIDER=jwt

# --- AI (optional) ---
# Leave empty to use the scripted/heuristic fallback for reports + transforms.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Server ---
PORT=4000

# --- Frontend ---
VITE_API_URL=/api

# --- Production (ignored in dev) ---
# NODE_ENV=production turns on the SPA static serving + JSON logging + CORS lockdown.
NODE_ENV=development
# Comma-separated origin allowlist for CORS in production. Leave empty when the
# API serves the SPA same-origin (the default container setup).
CORS_ORIGIN=
# Absolute path to the built frontend (app/dist) the API should serve.
# Empty => resolved relative to the server build. The Docker image sets this.
STATIC_DIR=
# Force static SPA serving outside production (accepts 1/true). Usually unset.
SERVE_STATIC=
