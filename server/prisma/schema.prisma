// Intelligence Layer — Phase 1 Prisma schema.
// Unified Card table with a `track` discriminator; self-referential OrgNode tree;
// JWT auth (User/Session/UserScope); RBAC FieldRule diffs; and 1:1 mock-shape models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Track {
  SALES
  OPERATIONS
  WORKSHOP
  FINANCE
}

enum OrgKind {
  GROUP
  REGION
  COUNTRY
  COMPANY
}

enum ScopeType {
  group
  region
  country
  multi_company
  company
  self
}

enum UserStatus {
  active
  invited
  disabled
}

enum SharingMode {
  shared
  private
  group
}

enum RuleScope {
  ANY
  NL
  BE
  DE
  ROTTERDAM
}

// ---------------- Org tree (group → region → country → company) ----------------
model OrgNode {
  id        String    @id
  kind      OrgKind
  name      String
  code      String?
  meta      Json?
  settings  Json?
  overrides Json?
  parentId  String?
  parent    OrgNode?  @relation("OrgChildren", fields: [parentId], references: [id])
  children  OrgNode[] @relation("OrgChildren")

  fleetOps      FleetOperator[]
  invoices      Invoice[]
  entities      Entity[]
  usersPrimary  User[]          @relation("UserPrimaryScope")
  userScopes    UserScope[]

  @@index([parentId])
}

model CountryDefaults {
  code       String @id // NL | BE | LU | DE
  vat        String
  currency   String
  peppol     String
  languages  String
  fiscalYear String
}

// ---------------- Roles + users ----------------
model Role {
  id     String  @id
  name   String
  system Boolean @default(true)
  tracks String[]
  users  Int     @default(0)
  edit   String
  desc   String

  usersWithRole User[]      @relation("UserRole")
  scopes        UserScope[]
  fieldRules    FieldRule[]
}

model User {
  id           String     @id
  name         String
  email        String     @unique
  initials     String?
  passwordHash String
  roleId       String
  role         Role       @relation("UserRole", fields: [roleId], references: [id])
  scopeType    ScopeType
  scopeNodeId  String?
  scopeNode    OrgNode?   @relation("UserPrimaryScope", fields: [scopeNodeId], references: [id])
  scopeLabel   String?
  status       UserStatus @default(active)
  lastSeen     String?
  secondary    UserScope[]
  sessions     Session[]
  reports      Report[]
  dashboard    DashboardLayout?
  createdAt    DateTime   @default(now())
}

// Secondary scopes for a user (each is a role/scope pair).
model UserScope {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      String?
  role        Role?      @relation(fields: [roleId], references: [id])
  scopeType   ScopeType  @default(company)
  scopeNodeId String?
  scopeNode   OrgNode?   @relation(fields: [scopeNodeId], references: [id])
  scopeLabel  String?
  roleLabel   String?

  @@index([userId])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  revoked          Boolean  @default(false)

  @@index([userId])
}

// ---------------- RBAC field rules (diffs from DEFAULT_RULE) ----------------
model FieldRule {
  roleId     String
  role       Role      @relation(fields: [roleId], references: [id])
  dataTypeId String
  fieldId    String
  scope      RuleScope @default(ANY)
  visible    Boolean
  editable   Boolean
  masked     Boolean
  note       String?

  @@id([roleId, dataTypeId, fieldId, scope])
}

model RbacVersion {
  v        Int    @id
  when     String
  actor    String
  note     String
  // Full snapshot of the effective FieldRule set at save time — enables
  // transactional "revert to version".
  snapshot Json?
}

// ---------------- Stage config + cross-track triggers ----------------
model StageConfig {
  id    String @id @default(cuid())
  track Track
  order Int
  // stage definition
  stageId String
  label   String
  sla     Int
  lock    String?
  cta     String

  @@unique([track, stageId])
  @@index([track, order])
}

model CrossTrigger {
  id        String @id @default(cuid())
  whenTrack String
  whenStage String
  thenTrack String
  thenStage String
  note      String

  @@index([whenTrack, whenStage])
}

// ---------------- Domain mock-shape models ----------------
model FleetOperator {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  companyId String?
  company   OrgNode? @relation(fields: [companyId], references: [id])
  meta      Json?
}

model Invoice {
  id        String   @id @default(cuid())
  ref       String   @unique
  value     Int?
  due       String?
  status    String?
  companyId String?
  company   OrgNode? @relation(fields: [companyId], references: [id])
  meta      Json?
}

model VehicleTimeline {
  id            String          @id @default(cuid())
  customer      String
  vehicle       String
  contractValue Int?
  account       String?
  events        TimelineEvent[]
}

model TimelineEvent {
  id         String          @id @default(cuid())
  timelineId String
  timeline   VehicleTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  order      Int
  track      String
  stage      String
  detail     String?
  date       String?
  owner      String?
  state      String?
  docs       String[]

  @@index([timelineId, order])
}

// ---------------- Integrations / audit / reports / dashboard ----------------
model Integration {
  id         String  @id
  name       String
  kind       String
  direction  String
  logo       String
  status     String
  lastSync   String?
  throughput String?
  latency    String?
  desc       String?
  nango      Boolean @default(false)
  transforms Int     @default(0)
  meta       Json?
}

model AuditEntry {
  id        String          @id @default(cuid())
  day       String?
  time      String?
  actor     String
  actorRole String?
  verb      String
  target    String?
  track     String
  kind      String          @default("normal")
  icon      String?
  isSystem  Boolean         @default(false)
  cascades  AuditCascade[]
  createdAt DateTime        @default(now())
  meta      Json?

  @@index([track])
}

model AuditCascade {
  id      String     @id @default(cuid())
  auditId String
  audit   AuditEntry @relation(fields: [auditId], references: [id], onDelete: Cascade)
  order   Int        @default(0)
  track   String
  text    String

  @@index([auditId, order])
}

model Report {
  id          String   @id @default(cuid())
  title       String
  spec        Json
  prose       Json
  when        String
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model DashboardLayout {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  charts Json
}

model DataSharing {
  id   String      @id @default(cuid())
  type String      @unique
  mode SharingMode
  note String
}

// Per-user settings (the Settings → Notifications & rules toggles).
model UserPreference {
  userId    String   @id
  prefs     Json
  updatedAt DateTime @updatedAt
}

// Customer-portal messages to the account team.
model PortalMessage {
  id        String   @id @default(cuid())
  operator  String?
  author    String?
  when      String
  body      String
  createdAt DateTime @default(now())
}

// ---------------- Generic entity meta-model (Phase 1a, parallel to Card/Vehicle) ----------------
model TrackDef {
  id      String       @id @default(cuid())
  key     String       @unique
  label   String
  color   String?
  icon    String?
  order   Int          @default(0)
  builtin Boolean      @default(false)
  stages  StageDef[]
  types   EntityType[]
}

model StageDef {
  id      String   @id @default(cuid())
  trackId String
  track   TrackDef @relation(fields: [trackId], references: [id], onDelete: Cascade)
  order   Int
  stageId String
  label   String
  sla     Int      @default(0)
  lock    String?
  cta     String   @default("")

  @@unique([trackId, stageId])
  @@index([trackId, order])
}

model EntityType {
  id        String     @id @default(cuid())
  key       String     @unique
  label     String
  kind      String // 'pipeline' | 'reference'
  trackId   String?
  track     TrackDef?  @relation(fields: [trackId], references: [id])
  icon      String?
  color     String?
  order     Int        @default(0)
  builtin   Boolean    @default(false)
  fieldDefs FieldDef[]
  entities  Entity[]
}

model FieldDef {
  id           String     @id @default(cuid())
  entityTypeId String
  entityType   EntityType @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  key          String
  label        String
  category     String?
  dataKind     String     @default("text") // text|money|date|select|number|bool
  order        Int        @default(0)
  builtin      Boolean    @default(false)

  @@unique([entityTypeId, key])
  @@index([entityTypeId, order])
}

model Entity {
  id           String     @id
  tenantId     String?
  entityTypeId String
  entityType   EntityType @relation(fields: [entityTypeId], references: [id])
  companyId    String?
  company      OrgNode?   @relation(fields: [companyId], references: [id])

  // shared display envelope (indexed scalar columns)
  title    String
  value    Int?
  owner    String?
  status   String?
  sub      String?
  sources  String[]
  fields   Json?
  archived Boolean  @default(false)

  // pipeline-kind only (null for reference)
  trackId      String?
  stageId      String?
  stageName    String?
  days         Int      @default(0)
  daysLabel    String?
  cta          String?
  awaitingSign Boolean  @default(false)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, companyId, entityTypeId, trackId, stageId])
  @@index([tenantId, trackId, stageId, status])
}
